import Foundation

/// Local GitHub OAuth App credentials — copy this file to `Secrets.swift` (gitignored) and
/// fill in your own values. Register a GitHub OAuth App at:
/// https://github.com/settings/developers
///
/// `Secrets.swift` is intentionally not committed to this repo (this repo is public) — every
/// user of this template should register their own OAuth App rather than share credentials.
enum Secrets {
    static let githubClientId = "YOUR_GITHUB_OAUTH_CLIENT_ID"
    static let githubClientSecret = "YOUR_GITHUB_OAUTH_CLIENT_SECRET"
}
